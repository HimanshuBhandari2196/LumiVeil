# Copy this file to .env and fill in your own values
# Never commit your actual .env file to Git

# Secret key LumiVeil uses to authenticate requests between the
# extension and the backend. Pick any random string.
LUMIVEIL_API_KEY=change-this-to-your-own-secret-key

# Your Hive Moderation API key (from hivemoderation.com)
HIVE_API_KEY=your-hive-api-key-here
