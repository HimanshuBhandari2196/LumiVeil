# -----------------------------------------------------------------------
# LumiVeil — environment variables
# Copy this file to .env and fill in your real values.
# Never commit your actual .env file to Git.
# -----------------------------------------------------------------------

# Internal secret used to authenticate requests from the extension.
# Pick any random string — keep it private.
LUMIVEIL_API_KEY=change-this-to-your-own-secret-key

# -----------------------------------------------------------------------
# IMAGE ANALYSIS PROVIDER
# Set to the provider you want to use. Currently supported: sightengine
# To add Hive later: set to 'hive' and uncomment HIVE_API_KEY below.
# -----------------------------------------------------------------------
IMAGE_ANALYSIS_PROVIDER=sightengine

# Sightengine credentials — sign up free at dashboard.sightengine.com
SIGHTENGINE_API_USER=your-api-user-here
SIGHTENGINE_API_SECRET=your-api-secret-here

# Hive credentials — enterprise only, uncomment when ready
# HIVE_API_KEY=your-hive-api-key-here
